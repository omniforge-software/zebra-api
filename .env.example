# Non-sensitive config — copy to .env and adjust values.
# SECRET_KEY and ADMIN_PASSWORD_HASH must NOT go here.
# Put them in docker-compose.override.yml (gitignored) with $$ escaping.
# See docker-compose.override.yml for the format.

ADMIN_USERNAME=admin
SCAN_SUBNETS=192.168.45.0/24
SCAN_ON_STARTUP=true
SCAN_PORTS=9100,515,631,80
PRINTER_CONNECT_TIMEOUT_SECONDS=3
PRINTER_WRITE_TIMEOUT_SECONDS=5
PRINTER_READ_TIMEOUT_SECONDS=3
PRINTER_STATUS_TIMEOUT_SECONDS=2
MAX_PRINT_QUANTITY=100
JOB_RETENTION_DAYS=31
CLEANUP_INTERVAL_MINUTES=60
COOKIE_SECURE=false
